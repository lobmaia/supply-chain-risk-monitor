APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./data/supply_chain_risk.db
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_PORT=8501
FRONTEND_API_BASE_URL=http://127.0.0.1:8000
INGESTION_ENABLED=true
INGESTION_INTERVAL_SECONDS=900
INGESTION_REQUEST_TIMEOUT_SECONDS=10
INGESTION_MAX_RETRIES=3
INGESTION_RETRY_BACKOFF_SECONDS=1.5
RSS_FEED_URLS=https://www.freightwaves.com/news/feed,https://www.supplychaindive.com/feeds/news/
RELEVANCE_THRESHOLD=0.35
PROCESSING_ENABLED=true
RISK_SCORING_ENABLED=true
RISK_ARTICLE_FLAG_THRESHOLD=0.6
RISK_SPIKE_DELTA_THRESHOLD=0.2
RISK_SPIKE_RATIO_THRESHOLD=1.35
RISK_SPIKE_BASELINE_POINTS=3
WATCHLIST_SEED_ITEMS=Intel|company|intel corporation,TSMC|company|taiwan semiconductor,Panama Canal|region|panama canal,Copper|commodity|copper,Semiconductors|commodity|chips
